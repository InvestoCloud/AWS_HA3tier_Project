aws_region   = "us-east-1"
project_name = "cloudops"
environment  = "dev"

vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24",
  "10.0.3.0/24"
]

private_app_subnet_cidrs = [
  "10.0.11.0/24",
  "10.0.12.0/24",
  "10.0.13.0/24"
]

private_db_subnet_cidrs = [
  "10.0.21.0/24",
  "10.0.22.0/24",
  "10.0.23.0/24"
]

enable_nat_gateway = true

instance_type        = "t3.micro"
asg_min_size         = 3
asg_desired_capacity = 3
asg_max_size         = 6

db_engine            = "postgres"
db_name              = "appdb"
db_username          = "dbadmin"
db_password          = "CHANGE_ME_DO_NOT_COMMIT_REAL_PASSWORD"
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_multi_az          = false

notification_email = "your-email@example.com"

scale_out_cpu_threshold = 60
scale_in_cpu_threshold  = 30
scaling_cooldown        = 300

ec2_cpu_alarm_threshold          = 70
alb_5xx_alarm_threshold          = 5
unhealthy_host_threshold         = 1
rds_cpu_alarm_threshold          = 80
rds_free_storage_threshold_bytes = 2147483648

hosted_zone_name = "example.com"
domain_name      = "app.example.com"

enable_waf_rate_limit = true
waf_rate_limit        = 2000